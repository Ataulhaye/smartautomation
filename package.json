{
    "name": "smartautomation",
    "displayName": "smartautomation",
    "description": "Automates the code comments and integration testing",
    "version": "0.0.1",
    "engines": {
        "vscode": "^1.95.3"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onCommand:smartautomation.showTextInOutput",
        "onCommand:smartautomation.showTextAndSaveToFile",
        "onCommand:smartautomation.sendToLLM"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "smartautomation.showTextInOutput",
                "title": "Show Text in Output Panel"
            },
            {
                "command": "smartautomation.showTextAndSaveToFile",
                "title": "Show Text and Save to File"
            },
            {
                "command": "smartautomation.sendToLLM",
                "title": "Send Text to Local LLM"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "compile": "npm run check-types && npm run lint && node esbuild.js",
        "watch": "npm-run-all -p watch:*",
        "watch:esbuild": "node esbuild.js --watch",
        "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
        "package": "npm run check-types && npm run lint && node esbuild.js --production",
        "compile-tests": "tsc -p . --outDir out",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "npm run compile-tests && npm run compile && npm run lint",
        "check-types": "tsc --noEmit",
        "lint": "eslint src",
        "test": "vscode-test"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.9",
        "@types/node": "20.x",
        "@types/node-fetch": "^2.6.12",
        "@types/vscode": "^1.95.0",
        "@typescript-eslint/eslint-plugin": "^8.10.0",
        "@typescript-eslint/parser": "^8.7.0",
        "@vscode/test-cli": "^0.0.10",
        "@vscode/test-electron": "^2.4.1",
        "esbuild": "^0.24.0",
        "eslint": "^9.13.0",
        "npm-run-all": "^4.1.5",
        "typescript": "^5.6.3"
    },
    "dependencies": {
        "node-fetch": "^2.7.0"
    }
}